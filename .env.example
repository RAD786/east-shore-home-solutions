# ─────────────────────────────────────────────────────────────
# East Shore Home Solutions — Environment Variables
# Copy to .env.local and fill in real values when integrations go live.
# All integrations are OPTIONAL — the contact form works (logs only)
# even when none of these are set. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata, canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.eastshorehomesolutions.com

# Owner inbox for new-lead notifications
LEAD_NOTIFY_EMAIL=EastshorepropertyLLC@gmail.com

# Owner phone for SMS lead alerts (E.164 format)
OWNER_PHONE=+16099941137

# ── Resend (transactional email) ──
# Set RESEND_API_KEY to enable owner + customer confirmation emails.
# RESEND_FROM_EMAIL must be a verified sending address/domain in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=leads@eastshorehomesolutions.com

# ── Twilio (owner SMS alerts) ──
# Set all three to enable SMS alerts to OWNER_PHONE.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── GoHighLevel (GHL) inbound webhook ──
# Set to POST each lead into GHL (creates contact/opportunity).
GHL_WEBHOOK_URL=
